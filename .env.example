MCP_TOKEN=

# Comma separated paths that searchhelper is allowed to search.
SEARCHHELPER_ROOTS=/host/data/documents,/host/data/projects

# Search engine order: everything,plocate.
SEARCHHELPER_ENGINES=everything,plocate

# Timeout in seconds for each backend call (Everything HTTP request, plocate command). Default 10.
SEARCHHELPER_COMMAND_TIMEOUT=10

# Everything HTTP server, e.g. http://host.docker.internal:8081/
SEARCHHELPER_EVERYTHING_URL=
SEARCHHELPER_EVERYTHING_USERNAME=
SEARCHHELPER_EVERYTHING_PASSWORD=

# Optional Windows-to-container path mapping for Everything results.
# Format: C:\Data=>/host/data;D:\=>/host/d
SEARCHHELPER_PATH_MAPPINGS=C:\Data=>/host/data
